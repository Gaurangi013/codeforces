Logic
Har internal node pe:
Left subtree ka total path cost nikalo
Right subtree ka total path cost nikalo
Dono ka difference nikalo
Jo chhota hai usme difference add karo
Difference ko answer me add karo
Phir parent ko return karo:

//Code 
class Solution {
    public int minIncrements(int n, int[] cost) {
        int res = 0;
        for(int i = n/2;i>=1;i--){
            int left = cost[2*i-1];
            int right = cost[2*i];

            res+= Math.abs(left-right);

            cost[i-1]+=Math.max(left,right);
        }
        return res;
    }
}

